---
import { getCollection, getEntry } from "astro:content";
import { getBuildMode } from "@/config";
import {
  expandEngineer,
  expandProject,
  isProjectVisible,
  isProjectInStats,
  buildLookup,
  resolveRole,
  resolveTechTag,
  calculateAge,
  calculateExperienceYears,
  calculatePeriodLabel,
  calculateTagCumulativeYears,
  calculateTagProjectCount,
  phaseLabels,
  phaseOrder,
} from "@/domain";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
import Terminal from "@/components/Terminal/Terminal.astro";
import { ModeToggle } from "@/components/ModeToggle/ModeToggle";
import "../styles/globals.css";

const mode = getBuildMode();

const engineerEntry = await getEntry("engineer", "me");
const engineer = engineerEntry ? expandEngineer(engineerEntry.data, mode) : null;

const projectEntries = await getCollection("projects");
const techTagEntries = await getCollection("techTags");
const industryTagEntries = await getCollection("industryTags");
const roleEntries = await getCollection("roles");
const companyEntries = await getCollection("companies");

// 参照解決用 Lookup
const techTagsLookup = buildLookup(
  techTagEntries.map((e) => ({ id: e.id, data: e.data })),
);
const industryTagsLookup = buildLookup(
  industryTagEntries.map((e) => ({ id: e.id, data: e.data })),
);
const rolesLookup = buildLookup(
  roleEntries.map((e) => ({ id: e.id, data: e.data })),
);
const companiesLookup = buildLookup(
  companyEntries.map((e) => ({ id: e.id, data: e.data })),
);

// プロジェクトを展開
const allProjects = projectEntries.map((e) => ({
  ...expandProject(e.data, mode),
  slug: e.id,
}));

// period.start desc + 同期間時は slug ASC (= No 昇順) で安定化
const visibleProjects = allProjects
  .filter((p) => isProjectVisible(p.visibility, mode))
  .sort((a, b) => {
    if (a.period.start !== b.period.start) {
      return a.period.start < b.period.start ? 1 : -1;
    }
    return parseInt(a.slug, 10) - parseInt(b.slug, 10);
  });

const statsProjects = allProjects.filter((p) => isProjectInStats(p.visibility));

// 同じ company の参画回数 + 案件リスト (2+ 件あればリピート参画として front に出す)
const companyEngagements = new Map<
  string,
  { id: string; name: string; projects: typeof visibleProjects }
>();
for (const p of visibleProjects) {
  if (!p.company) continue;
  const display = companiesLookup.get(p.company)?.public.name ?? p.company;
  const existing = companyEngagements.get(p.company);
  if (existing) {
    existing.projects.push(p);
  } else {
    companyEngagements.set(p.company, {
      id: p.company,
      name: display,
      projects: [p],
    });
  }
}
const multiEngagementCompanies = Array.from(companyEngagements.values())
  .filter((c) => c.projects.length >= 2)
  .sort((a, b) => b.projects.length - a.projects.length);

// 集計: 技術タグの累積経験年数 (baseName で集約)
const projectsWithBaseNames = statsProjects.map((p) => ({
  techTagBaseNames: p.techTags
    .map((id) => techTagsLookup.get(id)?.public.baseName)
    .filter((n): n is string => Boolean(n)),
  period: p.period,
}));

const baseNameMap = new Map<
  string,
  { baseName: string; category: string; cumulativeYears: number; projectCount: number }
>();
for (const tag of techTagsLookup.values()) {
  const baseName = tag.public.baseName;
  if (baseNameMap.has(baseName)) continue;
  baseNameMap.set(baseName, {
    baseName,
    category: tag.public.category,
    cumulativeYears: calculateTagCumulativeYears(baseName, projectsWithBaseNames),
    projectCount: calculateTagProjectCount(baseName, projectsWithBaseNames),
  });
}
const uniqueTechTagStats = Array.from(baseNameMap.values())
  .filter((t) => t.cumulativeYears > 0 || t.projectCount > 0)
  .sort((a, b) => b.cumulativeYears - a.cumulativeYears);

// 経験年数は「業界に居る期間」(暦レンジ) として archived も含める
const experienceYears =
  allProjects.length > 0
    ? calculateExperienceYears(allProjects.map((p) => p.period))
    : 0;

const phaseCounts = phaseOrder.map((key) => ({
  key,
  label: phaseLabels[key],
  count: statsProjects.filter((p) => p.phases[key]).length,
}));

const roleCounts = Array.from(rolesLookup.entries())
  .map(([id, role]) => ({
    id,
    name: role.public.name,
    rank: role.public.rank,
    count: statsProjects.filter((p) => p.role === id).length,
  }))
  .sort((a, b) => a.rank - b.rank);

// 主要技術ヒートマップは Language/Framework のみ。Cloud/OS/Middleware/Tool/Database は「その他経験技術」枠に分離
const heatmapTechs = uniqueTechTagStats.filter(
  (t) => t.category === "Language" || t.category === "Framework",
);
const otherTechs = uniqueTechTagStats.filter(
  (t) => t.category !== "Language" && t.category !== "Framework",
);
const maxTechYears = heatmapTechs[0]?.cumulativeYears ?? 1;
const primaryTech = heatmapTechs[0];
const age = engineer?.birthDate ? calculateAge(engineer.birthDate) : null;
---

<!doctype html>
<html lang="ja" class="h-full dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link
      rel="icon"
      type="image/svg+xml"
      href={`${import.meta.env.BASE_URL}favicon.svg`}
    />
    <title>Engineer Skill Map</title>
    <script is:inline>
      // モード初期判定 (CSS が効くより先に data-mode を決め、FOUC を防ぐ)
      // 既定: plain (初回訪問は HTML スキルシート)。localStorage で "world" を選択していれば world
      (function () {
        try {
          var params = new URLSearchParams(window.location.search);
          var mode = "plain";
          if (params.get("plain") === "1") {
            mode = "plain";
          } else if (
            window.matchMedia &&
            window.matchMedia("(prefers-reduced-motion: reduce)").matches
          ) {
            mode = "plain";
          } else {
            var stored = localStorage.getItem("skillmap.mode");
            if (stored === "world") mode = "world";
          }
          document.documentElement.dataset.mode = mode;
        } catch (e) {
          document.documentElement.dataset.mode = "plain";
        }
      })();
    </script>
    <style is:global>
      /* World モード時は HTML スキルシート (main) を隠す */
      html[data-mode="world"] main {
        display: none !important;
      }
      /* Plain モード時はターミナルを隠す (styles.css にも同等定義あり、二重化で確実に) */
      html[data-mode="plain"] .term-root {
        display: none !important;
      }
    </style>
  </head>
  <body class="text-foreground min-h-full">
    <Terminal />
    <ModeToggle client:load />

    <main class="relative mx-auto max-w-4xl space-y-10 p-6 md:p-10">
      <!-- HERO -->
      <section class="space-y-6 pt-12 md:pt-20">
        <div class="flex flex-wrap items-end justify-between gap-4">
          <div>
            <p
              class="text-[10px] tracking-[0.3em] text-blue-200/60 uppercase md:text-xs"
            >
              Engineer Skill Map
            </p>
            <h1
              class="mt-2 text-4xl font-bold tracking-tight text-white md:text-6xl"
            >
              {engineer?.name || "エンジニア スキルシート"}
            </h1>
            {
              engineer && (
                <p class="mt-3 text-sm text-blue-100/70">
                  {age && `${age}歳`}
                  {engineer.gender && ` ・ ${engineer.gender}`}
                </p>
              )
            }
          </div>
          <Badge
            variant="outline"
            className="bg-background/30 border-white/20 font-mono backdrop-blur"
            >{mode}</Badge
          >
        </div>

        <div class="grid grid-cols-2 gap-3 md:grid-cols-4">
          <div
            class="rounded-xl border border-white/10 bg-white/5 p-4 backdrop-blur-md"
          >
            <p class="text-[10px] tracking-widest text-blue-200/60 uppercase">
              経験年数
            </p>
            <p class="mt-1 text-3xl font-bold tabular-nums text-white">
              {experienceYears}<span class="ml-0.5 text-base font-normal"
                >年</span
              >
            </p>
          </div>
          <div
            class="rounded-xl border border-white/10 bg-white/5 p-4 backdrop-blur-md"
          >
            <p class="text-[10px] tracking-widest text-blue-200/60 uppercase">
              案件数
            </p>
            <p class="mt-1 text-3xl font-bold tabular-nums text-white">
              {statsProjects.length}<span class="ml-0.5 text-base font-normal"
                >件</span
              >
            </p>
          </div>
          <div
            class="rounded-xl border border-white/10 bg-white/5 p-4 backdrop-blur-md"
          >
            <p class="text-[10px] tracking-widest text-blue-200/60 uppercase">
              主要技術
            </p>
            <p class="mt-1 truncate text-2xl font-bold text-white">
              {primaryTech?.baseName ?? "-"}
            </p>
          </div>
          <div
            class="rounded-xl border border-white/10 bg-white/5 p-4 backdrop-blur-md"
          >
            <p class="text-[10px] tracking-widest text-blue-200/60 uppercase">
              勤務可能地域
            </p>
            <p class="mt-1 text-2xl font-bold text-white">
              {engineer?.workableArea ?? "-"}
            </p>
          </div>
        </div>

        {
          engineer?.selfPr && (
            <Card className="bg-card/40 border-white/10 backdrop-blur-md">
              <CardContent className="pt-6">
                <p class="text-sm leading-relaxed whitespace-pre-line text-blue-50/90">
                  {engineer.selfPr}
                </p>
              </CardContent>
            </Card>
          )
        }
      </section>

      <!-- 主要技術 -->
      <section>
        <h2 class="mb-4 text-xl font-semibold text-white">主要技術</h2>
        <Card className="bg-card/40 border-white/10 backdrop-blur-md">
          <CardContent className="space-y-4 pt-6">
            {
              heatmapTechs.length === 0 ? (
                <p class="text-muted-foreground text-sm">技術タグ未登録</p>
              ) : (
                <ul class="space-y-2.5">
                  {heatmapTechs.slice(0, 12).map((t) => (
                    <li class="grid grid-cols-[72px_minmax(0,1fr)_auto] items-center gap-2 text-sm sm:grid-cols-[88px_128px_minmax(0,1fr)_auto] sm:gap-3">
                      <Badge
                        variant="outline"
                        className="justify-center border-white/20 font-mono text-[10px] text-blue-100/80"
                      >
                        {t.category}
                      </Badge>
                      <span class="truncate font-medium text-white">
                        {t.baseName}
                      </span>
                      <div class="hidden h-1.5 max-w-[280px] overflow-hidden rounded-full bg-white/10 sm:block">
                        <div
                          class="h-full rounded-full bg-gradient-to-r from-blue-400 to-cyan-300"
                          style={`width: ${Math.min(100, (t.cumulativeYears / maxTechYears) * 100)}%`}
                        />
                      </div>
                      <span class="text-right text-xs whitespace-nowrap tabular-nums text-blue-100/60">
                        {t.cumulativeYears}年・{t.projectCount}件
                      </span>
                    </li>
                  ))}
                </ul>
              )
            }
            {
              otherTechs.length > 0 && (
                <div class="border-t border-white/10 pt-3 text-xs leading-relaxed text-blue-100/50">
                  <span class="mr-2 text-[10px] tracking-widest text-blue-200/60 uppercase">
                    その他
                  </span>
                  {otherTechs.map((t) => t.baseName).join(" · ")}
                </div>
              )
            }
          </CardContent>
        </Card>
      </section>

      <!-- フェーズ + 役割 -->
      <section class="grid grid-cols-1 gap-4 md:grid-cols-2">
        <Card className="bg-card/40 border-white/10 backdrop-blur-md">
          <CardHeader>
            <CardTitle className="text-base text-white">担当工程</CardTitle>
          </CardHeader>
          <CardContent>
            <ul class="space-y-1.5 text-sm">
              {
                phaseCounts.map((p) => (
                  <li class="flex items-center gap-2">
                    <span class="flex-1 text-blue-50/80">{p.label}</span>
                    <Badge
                      variant={p.count > 0 ? "default" : "outline"}
                      className={
                        p.count > 0
                          ? "bg-blue-500/30 text-blue-50 border-blue-300/30"
                          : "border-white/15 text-blue-100/40"
                      }
                    >
                      {p.count}件
                    </Badge>
                  </li>
                ))
              }
            </ul>
          </CardContent>
        </Card>
        <Card className="bg-card/40 border-white/10 backdrop-blur-md">
          <CardHeader>
            <CardTitle className="text-base text-white">役割</CardTitle>
          </CardHeader>
          <CardContent>
            <ul class="space-y-1.5 text-sm">
              {
                roleCounts.map((r) => (
                  <li class="flex items-center gap-2">
                    <span class="flex-1 text-blue-50/80">{r.name}</span>
                    <Badge
                      variant={r.count > 0 ? "default" : "outline"}
                      className={
                        r.count > 0
                          ? "bg-blue-500/30 text-blue-50 border-blue-300/30"
                          : "border-white/15 text-blue-100/40"
                      }
                    >
                      {r.count}件
                    </Badge>
                  </li>
                ))
              }
            </ul>
          </CardContent>
        </Card>
      </section>

      <!-- 複数案件参画した会社 (リピート参画) -->
      {
        multiEngagementCompanies.length > 0 && (
          <section>
            <h2 class="mb-4 flex items-baseline gap-2 text-xl font-semibold text-white">
              複数案件参画した会社
              <span class="text-sm font-normal text-emerald-100/50">
                ({multiEngagementCompanies.length}社)
              </span>
            </h2>
            <div class="grid grid-cols-1 gap-3 md:grid-cols-2">
              {multiEngagementCompanies.map((c) => (
                <Card className="bg-card/40 border-emerald-300/20 backdrop-blur-md">
                  <CardHeader className="pb-3">
                    <div class="flex items-baseline gap-2">
                      <h3 class="text-base font-semibold text-white">
                        @{c.name}
                      </h3>
                      <Badge className="bg-emerald-400/20 text-emerald-50 border-emerald-300/40">
                        ×{c.projects.length}件
                      </Badge>
                    </div>
                  </CardHeader>
                  <CardContent className="pt-0">
                    <ul class="space-y-1 text-xs text-blue-100/70">
                      {c.projects.map((p) => (
                        <li class="flex items-baseline gap-2">
                          <span class="font-mono text-blue-200/40 tabular-nums">
                            No.{parseInt(p.slug, 10)}
                          </span>
                          <span class="min-w-0 flex-1 truncate">{p.name}</span>
                          <span class="shrink-0 text-blue-100/40 tabular-nums">
                            {p.period.start}
                          </span>
                        </li>
                      ))}
                    </ul>
                  </CardContent>
                </Card>
              ))}
            </div>
          </section>
        )
      }

      <!-- プロジェクト一覧 -->
      <section>
        <h2 class="mb-4 flex items-baseline gap-2 text-xl font-semibold text-white">
          参画プロジェクト
          <span class="text-sm font-normal text-blue-100/50"
            >({visibleProjects.length}件)</span
          >
        </h2>
        <div class="space-y-3">
          {
            visibleProjects.map((p) => {
              const role = resolveRole(p.role, rolesLookup);
              const phaseList = phaseOrder
                .filter((k) => p.phases[k])
                .map((k) => phaseLabels[k]);
              return (
                <article class="bg-card/40 space-y-2 rounded-lg border border-white/10 p-4 backdrop-blur-md">
                  <div class="flex flex-wrap items-baseline gap-2">
                    <Badge
                      variant="outline"
                      className="border-white/20 font-mono text-blue-100/70"
                    >
                      No.{parseInt(p.slug, 10)}
                    </Badge>
                    <h3 class="text-base font-semibold text-white">{p.name}</h3>
                    <span class="ml-auto text-xs text-blue-100/50 tabular-nums">
                      {p.period.start} 〜 {p.period.end ?? "現在"} ・{" "}
                      {calculatePeriodLabel(p.period)}
                    </span>
                  </div>
                  <p class="text-sm leading-relaxed whitespace-pre-line text-blue-50/70">
                    {p.summary}
                  </p>
                  {(p.scale || phaseList.length > 0) && (
                    <div class="space-y-0.5 text-xs text-blue-100/60">
                      {p.scale && (
                        <div>
                          <span class="text-blue-200/40">規模</span>: 全体
                          {" "}{p.scale.total}人 / チーム {p.scale.team}人
                        </div>
                      )}
                      {phaseList.length > 0 && (
                        <div>
                          <span class="text-blue-200/40">担当工程</span>:{" "}
                          {phaseList.join(" / ")}
                        </div>
                      )}
                    </div>
                  )}
                  <div class="flex flex-wrap gap-1.5">
                    {role && (
                      <Badge className="bg-blue-500/30 text-blue-50 border-blue-300/30">
                        {role.public.name}
                      </Badge>
                    )}
                    {p.company &&
                      (() => {
                        const engagement = companyEngagements.get(p.company);
                        const displayName = engagement?.name ?? p.company;
                        const count = engagement?.projects.length ?? 0;
                        const isMulti = count >= 2;
                        return (
                          <Badge
                            variant="outline"
                            className={
                              isMulti
                                ? "border-emerald-300/50 bg-emerald-400/20 text-[10px] text-emerald-50"
                                : "border-emerald-300/30 bg-emerald-400/10 text-[10px] text-emerald-100/80"
                            }
                          >
                            @{displayName}
                            {isMulti && ` ×${count}`}
                          </Badge>
                        );
                      })()}
                    {p.techTags.map((id) => {
                      const tag = resolveTechTag(id, techTagsLookup);
                      return tag ? (
                        <Badge
                          variant="outline"
                          className="border-white/15 text-[10px] text-blue-100/80"
                        >
                          #{tag.public.name}
                        </Badge>
                      ) : null;
                    })}
                    {p.industryTags.map((id) => {
                      const tag = industryTagsLookup.get(id);
                      return tag ? (
                        <Badge
                          variant="outline"
                          className="border-purple-300/30 bg-purple-400/10 text-[10px] text-purple-100/80"
                        >
                          @{tag.public.name}
                        </Badge>
                      ) : null;
                    })}
                  </div>
                  {p.memo && (
                    <div class="mt-2 space-y-0.5 rounded-md border border-amber-300/20 bg-amber-300/10 p-2 text-xs">
                      <div class="flex items-center gap-1 font-semibold text-amber-100">
                        📝 メモ
                        <Badge variant="outline" className="border-amber-300/30 text-[10px] text-amber-100">
                          selfOnly
                        </Badge>
                      </div>
                      <p class="whitespace-pre-line text-amber-50/80">{p.memo}</p>
                    </div>
                  )}
                </article>
              );
            })
          }
        </div>
      </section>

      <footer class="pt-8 text-center text-xs text-blue-100/30">
        v1 — generated from <code>private/</code> via Astro Content Layer
      </footer>
    </main>
  </body>
</html>
