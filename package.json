{
  "name": "engineer-skill-map",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "BUILD_MODE=local astro dev",
    "build": "BUILD_MODE=public astro build && yarn verify",
    "build:local": "BUILD_MODE=local astro build --outDir dist-local",
    "build:excel": "BUILD_MODE=excel tsx scripts/build-excel.ts",
    "verify": "tsx scripts/verify-no-leak.ts",
    "deploy": "yarn build && gh-pages -d dist --dotfiles --remove '**/*'",
    "preview": "astro preview",
    "astro": "astro"
  },
  "packageManager": "yarn@4.1.1",
  "dependencies": {
    "@astrojs/react": "^5.0.4",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.2.4",
    "astro": "^6.1.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "js-yaml": "^4.1.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "gh-pages": "^6.3.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
